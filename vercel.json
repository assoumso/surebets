{
  "version": 2,
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "api/index.js": {
      "memory": 2048,
    "maxDuration": 300
    }
  },
  "routes": [
    {
      "src": "/style.css",
      "dest": "/api/index.js"
    },
    {
      "src": "/app.js",
      "dest": "/api/index.js"
    },
    {
      "src": "/results.js",
      "dest": "/api/index.js"
    },
    {
      "src": "/subscriptions.js",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}